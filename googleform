<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Todoリスト</title>

<style>

/* Google Forms風ベース */

body {
    margin: 0;
    background: #f0ebf8;
    font-family: Roboto, Arial, sans-serif;
    font-size: 14px;
    color: #202124;
}

/* レイアウト */

.container {
    max-width: 640px;
    margin: 40px auto;
}

/* タイトルカード */

.title-card {
    background: white;
    border-top: 8px solid #673ab7;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

.title-card h1 {
    font-size: 24px;
    margin: 0;
}

.title-card p {
    margin-top: 6px;
    color: #5f6368;
    font-size: 14px;
}

/* 入力カード */

.input-card {
    background: white;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 16px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

/* textarea */

textarea {
    width: 100%;
    padding: 10px;
    font-size: 14px;
    border: 1px solid #dadce0;
    border-radius: 4px;
    resize: vertical;
    box-sizing: border-box;
}

textarea:focus {
    outline: none;
    border-color: #673ab7;
}

/* ボタン */

button {
    height: 36px;
    padding: 0 16px;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    font-size: 14px;
    transition: 0.2s;
}

.btn-primary {
    background: #673ab7;
    color: white;
}

.btn-primary:hover {
    background: #5e35b1;
}

.btn-red {
    background: #d93025;
    color: white;
}

.btn-green {
    background: #188038;
    color: white;
}

.btn-gray {
    background: #9aa0a6;
    color: white;
}

.button-group {
    margin-top: 12px;
    margin-bottom: 24px;
}

.button-group button {
    margin-right: 8px;
}

/* セクションタイトル */

.section-title {
    font-size: 16px;
    font-weight: 500;
    margin-top: 24px;
}

/* Todoカード */

.todo-list {
    margin-top: 8px;
}

.todo-card {
    background: white;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 12px;
    border: 1px solid #dadce0;
    display: flex;
    align-items: flex-start;
    gap: 12px;

    transition: 0.2s;
}

.todo-card:hover {
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}

.todo-card.checked {
    border-color: #673ab7;
    background: #f3e8ff;
}

/* チェックボックス */

input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
}

/* テキスト */

.todo-text {
    white-space: pre-wrap;
    flex: 1;
}

/* ドラッグ */

.dragging {
    opacity: 0.5;
}

</style>

</head>

<body>

<div class="container">

<!-- タイトル -->

<div class="title-card">

<h1>Todoリスト</h1>

<p>ドラッグして並び替え可能</p>

</div>

<!-- 入力 -->

<div class="input-card">

<textarea
id="newTodo"
rows="3"
placeholder="Enterで追加 / Shift+Enterで改行"
></textarea>

<div style="margin-top:12px;">
<button
class="btn-primary"
onclick="addTodo()"
>
追加
</button>
</div>

</div>

<div class="section-title">
Todo
</div>

<div id="todoList" class="todo-list"></div>

<div class="button-group">

<button
class="btn-red"
onclick="deleteChecked('todo')"
>
削除
</button>

<button
class="btn-green"
onclick="completeChecked()"
>
完了
</button>

<button
class="btn-gray"
onclick="clearChecks('todo')"
>
全チェック解除
</button>

</div>

<div class="section-title">
完了リスト
</div>

<div id="doneList" class="todo-list"></div>

<div class="button-group">

<button
class="btn-red"
onclick="deleteChecked('done')"
>
削除
</button>

<button
class="btn-gray"
onclick="clearChecks('done')"
>
全チェック解除
</button>

</div>

</div>

<script>

/* データ */

let todos = [];
let dones = [];

/* 保存 */

function save() {

localStorage.setItem("todos",
JSON.stringify(todos));

localStorage.setItem("dones",
JSON.stringify(dones));

}

/* 読込 */

function load() {

todos =
JSON.parse(localStorage.getItem("todos") || "[]");

dones =
JSON.parse(localStorage.getItem("dones") || "[]");

render();

}

/* 追加 */

function addTodo() {

const textarea =
document.getElementById("newTodo");

const text = textarea.value;

if (!text.trim()) return;

todos.push({
text: text,
checked: false
});

textarea.value = "";

save();
render();

}

/* Enter追加 */

document
.getElementById("newTodo")
.addEventListener("keydown", e => {

if (e.key === "Enter" && !e.shiftKey) {

e.preventDefault();

addTodo();

}

});

/* 描画 */

function render() {

renderList("todoList", todos);

renderList("doneList", dones);

}

function renderList(id, list) {

const container =
document.getElementById(id);

container.innerHTML = "";

list.forEach((item, index) => {

const card =
document.createElement("div");

card.className =
"todo-card" +
(item.checked ? " checked" : "");

card.draggable = true;

/* Drag */

card.addEventListener("dragstart", () => {

card.classList.add("dragging");

});

card.addEventListener("dragend", () => {

card.classList.remove("dragging");

save();

});

/* Checkbox */

const checkbox =
document.createElement("input");

checkbox.type = "checkbox";

checkbox.checked = item.checked;

checkbox.onchange = () => {

item.checked =
checkbox.checked;

save();
render();

};

/* Text */

const text =
document.createElement("div");

text.className =
"todo-text";

text.textContent =
item.text;

card.appendChild(checkbox);
card.appendChild(text);

container.appendChild(card);

});

/* 並び替え */

container.addEventListener("dragover", e => {

e.preventDefault();

const dragging =
container.querySelector(".dragging");

const afterElement =
getDragAfterElement(container, e.clientY);

if (afterElement == null) {

container.appendChild(dragging);

}
else {

container.insertBefore(
dragging,
afterElement
);

}

updateOrder(container, list);

});

}

/* ドラッグ位置 */

function getDragAfterElement(container, y) {

const elements =
[...container.querySelectorAll(".todo-card:not(.dragging)")];

return elements.reduce((closest, child) => {

const box =
child.getBoundingClientRect();

const offset =
y - box.top - box.height / 2;

if (
offset < 0 &&
offset > closest.offset
) {

return {
offset: offset,
element: child
};

}
else {

return closest;

}

},
{ offset: Number.NEGATIVE_INFINITY }
).element;

}

/* 順序更新 */

function updateOrder(container, list) {

const cards =
container.children;

const newList = [];

for (let i = 0; i < cards.length; i++) {

const text =
cards[i]
.querySelector(".todo-text")
.textContent;

const item =
list.find(x => x.text === text);

if (item) {

newList.push(item);

}

}

if (container.id === "todoList") {

todos = newList;

}
else {

dones = newList;

}

save();

}

/* 削除 */

function deleteChecked(type) {

if (type === "todo") {

todos =
todos.filter(
item => !item.checked
);

}

if (type === "done") {

dones =
dones.filter(
item => !item.checked
);

}

save();
render();

}

/* 完了 */

function completeChecked() {

const remaining = [];

todos.forEach(item => {

if (item.checked) {

item.checked = false;

dones.push(item);

}
else {

remaining.push(item);

}

});

todos = remaining;

save();
render();

}

/* チェック解除 */

function clearChecks(type) {

let list =
type === "todo"
? todos
: dones;

list.forEach(item => {

item.checked = false;

});

save();
render();

}

load();

</script>

</body>
</html>
